modules = ["nodejs-20", "python-3.11", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["cacert", "cargo", "freetype", "glibcLocales", "lcms2", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "rustc", "tcl", "tk", "zlib"]

[userenv]

[userenv.shared]
ACCESS_TOKEN_EXPIRE_MINUTES = "60"
ALGORITHM = "HS256"
SECRET_KEY = "80d1fa9e0e09f6187b371a66dfcc728d44e2025c2fedac6027adfd8ff7c03ee1"
MELHORENVIO_CEP_ORIGEM = "02969000"
STORE_NAME = "ECOSOPIS Cosméticos Naturais"
STORE_PHONE = "11999999999"
STORE_ADDRESS = "Rua José Benedito Bispo"
STORE_NUMBER = "63"
STORE_DISTRICT = "Jardim Presidente Dutra"
STORE_CITY = "Guarulhos"
STORE_STATE = "SP"
STORE_DOCUMENT = "32273095805"
MELHORENVIO_CLIENT_ID = "23449"
MELHORENVIO_URL = "https://www.melhorenvio.com.br"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend Server"

[[workflows.workflow]]
name = "Frontend Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev -- -H 0.0.0.0 -p 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload"
waitForPort = 8000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "(cd /home/runner/workspace/backend && uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 4) & (cd /home/runner/workspace/frontend && PORT=5000 npm start)"]
build = ["bash", "-c", "cd /home/runner/workspace/frontend && npm run build"]
publicDir = "frontend/out"
